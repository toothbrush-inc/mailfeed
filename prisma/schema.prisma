generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  emails        Email[]
  links         Link[]
  linkReports   LinkReport[]
  hiddenDomains String[]  @default([])
  lastSyncAt    DateTime?
  syncPageToken       String?   // Gmail pagination token for continue sync (newer emails)
  oldestSyncPageToken String?   // Gmail pagination token for "sync older" (older emails)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application models
model Email {
  id          String    @id @default(cuid())
  userId      String
  gmailId     String    @unique
  threadId    String?
  subject     String?
  snippet     String?
  receivedAt  DateTime
  processedAt DateTime?
  rawContent  String?   @db.Text

  // AI-extracted tags from BAML IngestEmail
  tags        EmailTag[]
  ingestedAt  DateTime?

  // Vector embeddings for semantic search (managed via raw SQL)
  // embedding column is vector(768) type, not directly supported by Prisma
  embeddingStatus String?   @default("PENDING")  // PENDING, PROCESSING, COMPLETED, FAILED, SKIPPED
  embeddedAt      DateTime?
  embeddingError  String?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  links Link[]

  @@index([userId])
  @@index([gmailId])
  @@index([receivedAt])
  @@index([embeddingStatus])
}

enum EmailTag {
  ARTICLE_LINK
  REMINDER
  MEETING_INFO
  TODO
  OTHER
}

model Link {
  id           String  @id @default(cuid())
  userId       String
  emailId      String?
  parentLinkId String?
  url          String
  urlHash      String
  domain       String?

  // Final URL after redirects (for deduplication and display)
  finalUrl      String?
  finalUrlHash  String?
  finalDomain   String?
  wasRedirected Boolean  @default(false)

  title    String?
  description String?
  imageUrl String?

  // Content analysis
  contentText    String? @db.Text
  contentHtml    String? @db.Text  // Clean article HTML from Readability (preserves structure)
  rawHtml        String? @db.Text  // Raw HTML for AI fallback parsing
  summary        String? @db.Text
  readingTimeMin Int?
  wordCount      Int?

  // AI-generated fields
  aiSummary       String?  @db.Text
  aiKeyPoints     String[]
  aiCategory      String?
  aiTags          String[]
  // BAML IngestLink tag types
  linkTags        String[]  // ARTICLE, VIDEO, IMAGE, AUDIO, etc.
  contentTags     String[]  // TECHNOLOGY, BUSINESS, SCIENCE, etc.
  metadataTags    String[]  // OPEN_ACCESS, LOGIN_REQUIRED, PAYMENT_REQUIRED, etc.
  worthinessScore Float?
  uniquenessScore Float?
  isHighlighted   Boolean  @default(false)
  highlightReason String?

  // Fetch status
  fetchStatus   FetchStatus @default(PENDING)
  fetchError    String?
  contentSource String?     // "direct", "wayback", etc. - indicates where content was fetched from
  archivedUrl   String?     // Wayback Machine URL if content was fetched from archive
  isPaywalled   Boolean     @default(false)
  paywallType   String?

  // Read status
  isRead Boolean   @default(false)
  readAt DateTime?

  // Embedding for RAG (vector column managed via raw SQL)
  embeddingStatus String?   @default("PENDING")  // PENDING, PROCESSING, COMPLETED, FAILED, SKIPPED
  embeddedAt      DateTime?
  embeddingError  String?

  // Timestamps
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  fetchedAt  DateTime?
  analyzedAt DateTime?

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      Email?        @relation(fields: [emailId], references: [id], onDelete: SetNull)
  parentLink Link?         @relation("NestedLinks", fields: [parentLinkId], references: [id], onDelete: SetNull)
  childLinks Link[]        @relation("NestedLinks")
  categories LinkCategory[]
  reports    LinkReport[]

  @@unique([userId, urlHash])
  @@index([userId])
  @@index([emailId])
  @@index([parentLinkId])
  @@index([fetchStatus])
  @@index([aiCategory])
  @@index([isHighlighted])
  @@index([isRead])
  @@index([createdAt])
  @@index([worthinessScore])
  @@index([finalUrlHash])
  @@index([embeddingStatus])
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  color       String?
  icon        String?

  links LinkCategory[]

  @@index([slug])
}

model LinkCategory {
  linkId     String
  categoryId String
  confidence Float?

  link     Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([linkId, categoryId])
}

enum FetchStatus {
  PENDING
  FETCHING
  FETCHED
  ANALYZING
  COMPLETED
  FAILED
  PAYWALL_DETECTED
}

// User reports for links with fetch/parse issues
model LinkReport {
  id        String   @id @default(cuid())
  linkId    String
  userId    String
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([userId])
  @@index([createdAt])
}
