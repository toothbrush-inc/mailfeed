# ============================================
# MailFeed Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database ---
# For Docker (docker compose up) this is set automatically — no need to change.
# For local dev without Docker, point to your Postgres instance:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mailfeed"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key"

# --- Google OAuth (required) ---
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI: http://localhost:3000/api/auth/callback/google
# 4. Enable the Gmail API: https://console.cloud.google.com/apis/library/gmail.googleapis.com
# 5. Configure OAuth consent screen with gmail.readonly scope
GOOGLE_CLIENT_ID="google-client-id"
GOOGLE_CLIENT_SECRET="google-client-secret"

# --- Google Gemini API (required for AI analysis) ---
# Get a key from: https://aistudio.google.com/apikey
GEMINI_API_KEY="gemini-api-key"

# --- Optional: Alternative LLM providers for BAML ---
# These are only needed if you switch BAML functions to use OpenAI or Anthropic clients.
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYSIS=false
